# Production Environment Configuration
# Copy this file to .env.prod and fill in your values

# Application
NODE_ENV=production
PORT=3000

# Database Configuration
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password
DB_NAME=cleanreport_prod

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-cleanreport-bucket
AWS_S3_REGION=us-east-1

# Optional: AWS IAM Role (if using EC2 instance profile)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/CleanReportRole

# Security
JWT_SECRET=your_super_secure_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Monitoring & Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Deployment
DEPLOY_ENV=production
BACKUP_ENABLED=true

# External Services
# SENTRY_DSN=your_sentry_dsn_here
# REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com